# === AgentGuard — Environment Variables ===
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.

# --- LLM Provider API Keys ---
ANTHROPIC_API_KEY=sk-ant-PLACEHOLDER
OPENAI_API_KEY=sk-PLACEHOLDER

# --- Provider Failover Tuning (optional — defaults in config/settings.py) ---
# PROVIDER_PRIORITY=anthropic,openai
# PROVIDER_TIMEOUT_SECONDS=30
# PROVIDER_MAX_RETRIES=3
# CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# CIRCUIT_BREAKER_COOLDOWN_SECONDS=60

# --- Phase 2: Cost Governance ---
# BUDGET_PER_RUN_USD=5.0
# BUDGET_PER_USER_USD=50.0
# BUDGET_DEGRADATION_THRESHOLD=0.8

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_DB=agentguard
POSTGRES_USER=agentguard
POSTGRES_PASSWORD=agentguard


